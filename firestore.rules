rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: waitlist
    // Document ID: {username} (lowercase string)
    // Fields:
    //   - username: string (required, max 30 chars, lowercase) - The claimed username
    //   - createdAt: timestamp (required) - When the username was claimed
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidWaitlistUser(usernameId) {
      return hasOnlyAllowedFields(['username', 'createdAt']) &&
             hasRequiredFields(['username', 'createdAt']) &&
             validStringLength('username', 1, 30) &&
             request.resource.data.username == usernameId && // Ensure field matches doc ID
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /waitlist/{username} {
      // Anyone can check if a username exists (read)
      allow get: if true;
      // Do not allow listing all usernames for privacy
      allow list: if false;
      
      // Anyone can claim a username IF it doesn't already exist
      allow create: if !exists(/databases/$(database)/documents/waitlist/$(username)) && 
                    isValidWaitlistUser(username);
                    
      // Usernames cannot be updated or deleted once claimed
      allow update, delete: if false;
    }
  }
}
