{
  "entities": {
    "WaitlistUser": {
      "title": "WaitlistUser",
      "description": "A user who has claimed a username on the waitlist.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The claimed username (lowercase)."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the username was claimed."
        }
      },
      "required": ["username", "createdAt"]
    }
  },
  "firestore": {
    "/waitlist/{username}": {
      "schema": {
        "$ref": "#/entities/WaitlistUser"
      },
      "description": "Stores claimed usernames. The document ID is the lowercase username."
    }
  }
}
