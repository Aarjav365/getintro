# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase (https://supabase.com/dashboard — Project Settings > API)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"
# Same project URL for the API server (no VITE_ prefix)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Project Settings → API → service_role (server only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
# Long random string — used to hash email codes (rotate if leaked)
CLAIM_CODE_SECRET="YOUR_LONG_RANDOM_SECRET"

# Resend — https://resend.com/api-keys ; domains: https://resend.com/domains ; send API: https://resend.com/docs/api-reference/emails/send-email (Next.js guide uses same SDK: https://resend.com/docs/send-with-nextjs)
RESEND_API_KEY="re_..."
# Verified sender, e.g. "GetIntro <noreply@yourdomain.com>"
RESEND_FROM="Your App <noreply@yourdomain.com>"
# Shown in verification emails (optional)
APP_NAME="GetIntro"
# Public site URL for email footer (optional). On Vercel, VERCEL_URL is used if unset.
APP_URL="https://your-domain.com"

# API server port (optional; default 3005). Vite proxies /api here in dev.
# API_PORT=3005
